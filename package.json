{
  "name": "moodle-clients",
  "private": true,
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "bash ./scripts/dev-local.sh",
    "dev:apps": "node ./scripts/with-op-env.cjs turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "proxy:dev": "node ./scripts/with-op-env.cjs node ./scripts/moodle-proxy-dev.cjs",
    "web:dev": "bash ./scripts/web-local-dev.sh",
    "web:dev:live": "bun run --filter @moodle-clients/web dev",
    "web:dev:portless": "bun run web:dev",
    "services:dev": "bash ./scripts/start-local-moodle-services.sh",
    "services:test": "cd services/moodle && go test ./...",
    "services:stop": "bash ./scripts/stop-local-moodle-services.sh",
    "services:dev:docker": "bash ./scripts/start-local-moodle-services.sh",
    "services:dev:docker:stop": "bash ./scripts/stop-local-moodle-services.sh",
    "api-client:generate": "bun run --filter @moodle-clients/api-client generate",
    "api-client:generate:local": "MOODLE_SERVICES_OPENAPI_URL=http://127.0.0.1:8080/api/openapi.json bun run api-client:generate",
    "web:dev:expo": "bun run --filter @moodle-clients/web dev:expo",
    "web:build": "node ./scripts/with-op-env.cjs bun run --filter @moodle-clients/web build",
    "study:import": "bun ./scripts/import-study-bundle.mjs",
    "study:pipeline:cli": "node ./scripts/with-op-env.cjs bun ./scripts/study-pipeline-cli.ts",
    "study:pipeline:logs": "bun ./scripts/study-pipeline-logs.mjs",
    "mobile:dev": "node ./scripts/with-op-env.cjs node ./scripts/mobile-with-proxy-dev.cjs start",
    "mobile:start": "node ./scripts/with-op-env.cjs node ./scripts/mobile-with-proxy-dev.cjs start",
    "mobile:ios": "node ./scripts/with-op-env.cjs node ./scripts/mobile-with-proxy-dev.cjs ios",
    "mobile:android": "node ./scripts/with-op-env.cjs node ./scripts/mobile-with-proxy-dev.cjs android",
    "mobile:sentry:smoke": "node ./scripts/sentry-mobile-smoke-test.mjs",
    "moodle:fetch-login": "node ./scripts/with-op-env.cjs bun ./scripts/fhgr-fetch-login.mjs",
    "name:scan": "bun ./scripts/name-scan.ts",
    "webex:fetch-poc": "node ./scripts/with-op-env.cjs bun ./scripts/webex-fetch-poc.mjs",
    "extension:dev": "bun run --filter @moodle-clients/extension dev",
    "extension:build": "bun run --filter @moodle-clients/extension build"
  },
  "devDependencies": {
    "eas-cli": "^18.8.1",
    "eslint": "^9.39.1",
    "turbo": "^2.6.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0"
  },
  "dependencies": {
    "@openai/codex-sdk": "0.125.0",
    "@react-native-cookies/cookies": "^6.2.1",
    "commander": "^15.0.0",
    "ws": "^8.21.0"
  },
  "trustedDependencies": [
    "@clerk/shared"
  ]
}
