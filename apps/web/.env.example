# Both Clerk keys must come from the same Clerk application (API Keys page).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_MOODLE_CLIENT_DOWNLOAD_URL=https://expo.dev/accounts/omiq/projects/moodle-client
CLERK_SECRET_KEY=sk_test_...
MOODLE_SERVICES_URL=http://127.0.0.1:8080
# Optional. If unset, the app infers local/live from MOODLE_SERVICES_URL.
# Set this when intentionally developing against a specific backend profile.
MOODLE_BACKEND_PROFILE=local
MOODLE_WEB_COOKIE_SECRET=change-me
# Local docker default from docker-compose.dev.yml:
MOODLE_WEB_INTERNAL_SECRET=local-moodle-dev-internal-secret
# Optional: when set, the web chat tries this WebSocket stream first and falls
# back to /api/codex/run HTTP streaming if the socket cannot start cleanly.
NEXT_PUBLIC_CODEX_RUN_WS_URL=ws://localhost:3000/api/codex-run/ws
# Optional escape hatch for externally generated bundle files.
# Leave unset for the normal VPS pipeline through MOODLE_SERVICES_URL.
STUDY_BUNDLES_ROOT=/srv/moodle-study/legacy-study-bundles
